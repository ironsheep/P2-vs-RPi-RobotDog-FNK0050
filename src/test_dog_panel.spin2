{Spin2_v50}
'' =================================================================================================
''   File....... test_dog_panel.spin2
''   Purpose.... INTERACTIVE move panel in the PRODUCTION 3-cog shape. A DEBUG PLOT window of
''               CLICKABLE buttons (mouse) that POST commands through the production backend/IO
''               mailboxes (dog.postCommand / io.postCommand), with a live telemetry readout
''               (mode / battery / tilt / head / distance / ping-seq). Repeatable bench exercising:
''               click any move, any order, any number of times, instead of re-flashing a scripted
''               sequence. Complements (does NOT replace) the scripted end-marker drivers that remain
''               the formal 0.1.2 certification record.
''   Authors.... Stephen M Moraco -- (c) 2026 Iron Sheep Productions, LLC  (MIT)
'' =================================================================================================
'
'  INTERACTIVE (NOT headless) -- run in a WINDOWED terminal so the PLOT window + mouse/keyboard work:
'    pnut-ts -d -q src/test_dog_panel.spin2
'    cd src && pnut-term-ts -r test_dog_panel.bin -b 2000000      # bare BMP names resolve here
'  Assets (tools/gen_dog_panel_assets.py): dog_panel_bg.bmp, dog_btn_hi.bmp, dog_font.bmp, dog_modes.bmp.
'
'  >> LIFT / SUPPORT THE ROBOT << on launch: cog1 calibrates the gyro (hold still & level), then the
'  backend powers up RESTING in RELAX (soft-start: a gentle settle, not a stand). Load/servo switch ON;
'  ~1 kOhm series R into P9 for ECHO. Healthy battery.
'
'  BUTTON BEHAVIOR (the highlight tells you the kind):
'    * MOVE buttons (poses STAND/SIT/CROUCH/RELAX/STOP, gestures HELLO/SHAKE/SALUTE, HEAD pans):
'      MOMENTARY -- highlight while the move runs, clear when it COMPLETES.
'    * GAIT buttons (FWD/BACK/TURN/STEP): LATCHED -- stay highlighted while walking (a gait runs until
'      you press STOP or another move). Their cadence comes from the SPEED selector.
'    * SPEED (SLOW/NORM/FAST): a RADIO selector -- the chosen speed stays lit; it ONLY affects gaits.
'    * LED / RANGE: TOGGLES -- lit = feature ON, click again to turn off.   BEEP: one-shot flash.
'  Several can be lit at once (e.g. a gait + LED + RANGE + NORM) -- the panel is a live state display.
'  Keys mirror the buttons: 1 STAND 2 SIT 3 CROUCH 4 RELAX SPACE STOP | w FWD x BACK a TURN-L d TURN-R
'    z STEP-L c STEP-R | h HELLO k SHAKE u SALUTE | j/n/m HEAD 60/90/120 | l LED b BEEP g RANGE | -/0/= speed
'    o DOWN v BOW p PUSHUP y NOD i SPIN e SPEAK | r PARADE-REST (key only, grid is full)

CON
  _clkfreq      = 200_000_000
  DEBUG_BAUD    = 2_000_000

  ' ---- channel-gated diagnostics (DEBUG_MASK; {Spin2_v50} satisfies the v46+ requirement) ----
  ' A channel whose bit is clear in DEBUG_MASK compiles to ZERO code. Plain DEBUG() (banner, status,
  ' and the `pnl PLOT rendering) is always compiled and unaffected. To trace input again, OR DBG_INPUT
  ' (and DBG_MOUSE) into DEBUG_MASK and recompile.
  DBG_MOUSE  = 0                   ' raw mouse dump (noisiest)
  DBG_INPUT  = 1                   ' CLICK + KEY events
  DBG_CMD    = 2                   ' posted commands + LED/range/speed/beep/speak
  DBG_IMU    = 3                   ' IMU-after-settle leveling
  DEBUG_MASK = (1 << DBG_CMD) | (1 << DBG_IMU)              ' default: commands + IMU on; mouse/input off

  PIN_SCL       = 13
  PIN_SDA       = 15
  PIN_WS2812    = 8
  PIN_ECHO      = 9
  PIN_BUZZER    = 10
  PIN_TRIG      = 11

  COUNTDOWN_S   = 8
  COG_STACK     = 256
  INIT_MS       = 5000             ' allow cog1 init + gyro cal + power-on soft-start to RELAX

  LED_RAINBOW   = 5                ' isp_led_ring MODE_RAINBOW_CYCLE
  LED_MODE_COUNT = 6               ' OFF/SOLID/WIPE/CHASE/RAINBOW/RAINBOW_CYCLE -- LED button steps through these
  REFRESH_POLLS = 6                ' readout refresh every REFRESH_POLLS * 25 ms (~150 ms)
  BEEP_FLASH_POLLS = 8             ' BEEP highlight flash duration (~200 ms)
  SPIN_POLLS    = 80               ' SPIN = posted TURN, auto-STOP after ~2 s (80 * 25 ms)
  SPEAK_BARK_MS = 90               ' SPEAK buzzer "bark" duration
  GLYPH_MINUS   = 10

  ' button-kind tags for the move watcher
  #0, KIND_POSE, KIND_GEST, KIND_GAIT

  ' speed-selector slots (radio group) + default
  SPEED_SLOW = 21
  SPEED_NORM = 22
  SPEED_FAST = 23

  ' ---- layout (generated by tools/gen_dog_panel_assets.py; matches the BMPs) ----
  PANEL_W = 660
  PANEL_H = 510
  COLS = 6
  ROWS = 5
  CELL_W = 100
  CELL_H = 40
  PITCH_X = 106
  PITCH_Y = 48
  GRID_X = 15
  GRID_Y = 40
  RW = 22
  RH = 34
  MODE_CELL_W = 150
  MODE_CELL_H = 30
  LED_CELL_W = 150
  LED_CELL_H = 30

  ' readout field boxes (box_x, box_y, box_w) and digit slot-0 X (slots step by RW)
  RO_MODE_BX = 71
  RO_MODE_BY = 294
  RO_MODE_BW = 150
  RO_BATT_BX = 71
  RO_BATT_BY = 338
  RO_BATT_BW = 96
  RO_BATT_S0 = 75
  RO_HEAD_BX = 71
  RO_HEAD_BY = 382
  RO_HEAD_BW = 74
  RO_HEAD_S0 = 75
  RO_TILT_BX = 396
  RO_TILT_BY = 294
  RO_TILT_BW = 162
  RO_TILT_S0 = 400
  RO_DIST_BX = 396
  RO_DIST_BY = 338
  RO_DIST_BW = 96
  RO_DIST_S0 = 400
  RO_PING_BX = 396
  RO_PING_BY = 382
  RO_PING_BW = 118
  RO_PING_S0 = 400
  RO_LED_BX = 71
  RO_LED_BY = 426
  RO_LED_BW = 178
  RO_LED_S0 = 227
  RO_BOX_H = 38

OBJ
  dog     : "isp_robot_dog"                                  ' cog1: I2C bus owner, motion engine, mailbox A
  io      : "isp_io_controller"                              ' cog2: discrete pins (LED/buzzer/ultrasonic), mailbox B
  stack   : "isp_stack_check"                                ' COG stack-overflow detector

VAR
  long  activeMoveSlot                                       ' slot of the in-progress move (-1 none)
  long  activeMoveKind                                       ' KIND_POSE / KIND_GEST / KIND_GAIT
  long  movePhase                                            ' 0 waiting move-start, 1 waiting move-done
  long  moveTimer                                            ' polls since the move armed (safety timeout)
  long  ledMode                                              ' current LED pattern 0..5 (slot 18 lit when not OFF)
  long  rangeOn                                              ' ranging toggle state (slot 20 lit)
  long  speedSlot                                            ' currently-selected speed slot (radio: 21/22/23)
  long  beepTimer                                            ' polls remaining on the BEEP flash (0 = off)
  long  spinTimer                                            ' polls remaining before SPIN auto-STOPs (0 = off)
  long  gaitSpeed                                            ' deg/frame arg0 for gaits (set by the speed radio)
  long  prevLb                                               ' previous left-button state (press-edge detect)
  long  prevKey
  long  keyCode
  long  litCtr                                               ' poll counter gating the readout refresh
  long  rawCtr                                               ' INSTRUMENT: throttles raw-mouse logging
  long  mx, my, mwheel, mlb, mmb, mrb, mpix                  ' pc_mouse: MUST be 7 consecutive longs

DAT ' ---- cog launch stacks, each followed IMMEDIATELY by its overflow sentinel ----
  backendStack     LONG  0[COG_STACK]
  backendStackMark LONG  stack.DO_NOT_WRITE_MARK
  ioStack          LONG  0[COG_STACK]
  ioStackMark      LONG  stack.DO_NOT_WRITE_MARK

PUB main() | backendCog, ioCog, s
'' Launch the production 3-cog shape, open the panel window, and run the click/telemetry loop.

    waitms(100)
    DEBUG("=== MOVE PANEL (interactive, production 3-cog shape) ===")
    DEBUG(">> LIFT/SUPPORT THE ROBOT. cog1 calibrates gyro (hold still), then powers up RESTING (RELAX). <<")
    countdown()

    stack.prepStackForCheck(@ioStack, COG_STACK)
    stack.prepStackForCheck(@backendStack, COG_STACK)

    ioCog := cogspin(NEWCOG, io.start(PIN_WS2812, PIN_BUZZER, PIN_TRIG, PIN_ECHO), @ioStack)
    if ioCog < 0
        DEBUG("FAILED to start IO cog -- aborting")
        repeat
    io.setStackCheck(@ioStack, COG_STACK)
    DEBUG("IO cog alive in cog ", udec_(ioCog))

    backendCog := cogspin(NEWCOG, dog.start(PIN_SCL, PIN_SDA), @backendStack)
    if backendCog < 0
        DEBUG("FAILED to start backend cog -- aborting")
        repeat
    dog.setStackCheck(@backendStack, COG_STACK)
    DEBUG("backend cog ", udec_(backendCog), "; init + gyro cal + soft-start to RELAX...")
    waitms(INIT_MS)

    activeMoveSlot := -1
    gaitSpeed      := 15
    speedSlot      := SPEED_NORM
    ledMode        := 0
    rangeOn        := FALSE
    beepTimer      := 0
    prevLb         := 0
    prevKey        := 0

    setupWindow()
    hiBtn(speedSlot)                                         ' show the default speed selection (NORM)
    DEBUG(`pnl update)
    showLedMode(ledMode)                                     ' paint the initial LED-mode readout (OFF); refreshReadouts' update flips both
    refreshReadouts()
    DEBUG("panel ready -- click a button (or press its key)")

    repeat
        keyCode := 0
        DEBUG(`pnl `pc_key(@keyCode))                        ' poll keyboard (LAST in stmt)
        if keyCode <> prevKey
            prevKey := keyCode
            if keyCode
                DEBUG[DBG_INPUT]("KEY code=", sdec_(keyCode))
                if keyCode == "r" or keyCode == "R"          ' parade rest (no button slot -- direct key for now)
                    dog.postCommand(dog.CMD_PARADE_REST, 0, 0, 0, 0)
                    DEBUG[DBG_CMD]("PANEL parade rest")
                else
                    doSlot(keyToSlot(keyCode))

        DEBUG(`pnl `pc_mouse(@mx))                            ' poll mouse (LAST in stmt; 7 longs from @mx)
        if (mx >= 0) and ((rawCtr++ // 8) == 0)
            DEBUG[DBG_MOUSE]("RAW x=", sdec_(mx), " y=", sdec_(my), " lb=", sdec_(mlb))
        if (mlb <> 0) and (prevLb == 0)                      ' left-button press EDGE (lb = -1 when down)
            s := hitSlot(mx, my)
            DEBUG[DBG_INPUT]("CLICK raw x=", sdec_(mx), " y=", sdec_(my), " -> slot=", sdec_(s))
            doSlot(s)
        prevLb := mlb

        watchMove()                                          ' clear momentary highlights when moves complete; log IMU
        if beepTimer > 0
            if (--beepTimer) == 0
                restoreBtn(19)
                DEBUG(`pnl update)
        if spinTimer > 0
            if (--spinTimer) == 0
                postDog(dog.CMD_STOP, 0)                      ' SPIN done -> stop (watchMove clears slot 28 when GAITING ends)

        if (++litCtr) >= REFRESH_POLLS
            litCtr := 0
            refreshReadouts()
        waitms(25)

PRI doSlot(slot)
'' Dispatch one button/key action. slot < 0 or an undefined slot is a no-op.
    if slot < 0
        return
    case slot
        0 : postDog(dog.CMD_STAND,      0)
            startMove(0,  KIND_POSE)
        1 : postDog(dog.CMD_SIT,        0)
            startMove(1,  KIND_POSE)
        2 : postDog(dog.CMD_CROUCH,     0)
            startMove(2,  KIND_POSE)
        3 : postDog(dog.CMD_RELAX,      0)
            startMove(3,  KIND_POSE)
        4 : postDog(dog.CMD_STOP,       0)
            startMove(4,  KIND_POSE)
        6 : postDog(dog.CMD_FORWARD,    gaitSpeed)
            startMove(6,  KIND_GAIT)
        7 : postDog(dog.CMD_BACKWARD,   gaitSpeed)
            startMove(7,  KIND_GAIT)
        8 : postDog(dog.CMD_TURN_LEFT,  gaitSpeed)
            startMove(8,  KIND_GAIT)
        9 : postDog(dog.CMD_TURN_RIGHT, gaitSpeed)
            startMove(9,  KIND_GAIT)
        10: postDog(dog.CMD_STEP_LEFT,  gaitSpeed)
            startMove(10, KIND_GAIT)
        11: postDog(dog.CMD_STEP_RIGHT, gaitSpeed)
            startMove(11, KIND_GAIT)
        12: postDog(dog.CMD_HELLO,      0)
            startMove(12, KIND_GEST)
        13: postDog(dog.CMD_SHAKE,      0)
            startMove(13, KIND_GEST)
        14: postDog(dog.CMD_SALUTE,     0)
            startMove(14, KIND_GEST)
        15: postDog(dog.CMD_HEAD,       60)
            startMove(15, KIND_POSE)
        16: postDog(dog.CMD_HEAD,       90)
            startMove(16, KIND_POSE)
        17: postDog(dog.CMD_HEAD,       120)
            startMove(17, KIND_POSE)
        18: stepLed()
        19: beep()
        20: toggleRange()
        SPEED_SLOW: setSpeed(5,  SPEED_SLOW)
        SPEED_NORM: setSpeed(15, SPEED_NORM)
        SPEED_FAST: setSpeed(30, SPEED_FAST)
        24: postDog(dog.CMD_LIE_DOWN, 0)
            startMove(24, KIND_POSE)
        25: postDog(dog.CMD_BOW,      0)
            startMove(25, KIND_POSE)
        26: postDog(dog.CMD_PUSHUPS,  0)
            startMove(26, KIND_GEST)
        27: postDog(dog.CMD_NOD,      0)
            startMove(27, KIND_GEST)
        28: postDog(dog.CMD_TURN_LEFT, gaitSpeed)            ' SPIN = timed turn, auto-STOP after SPIN_POLLS
            startMove(28, KIND_GAIT)
            spinTimer := SPIN_POLLS
        29: speak()

PRI postDog(cmd, arg0)
    dog.postCommand(cmd, arg0, 0, 0, 0)
    DEBUG[DBG_CMD]("PANEL post cmd=", sdec_(cmd), " arg0=", sdec_(arg0))

PRI startMove(slot, kind)
'' Begin tracking a move: clear any previous move highlight, light this one, and arm the watcher.
'' MOMENTARY for poses/gestures/head (cleared on completion); LATCHED for gaits (cleared on STOP/other).
    if activeMoveSlot >= 0 and activeMoveSlot <> slot
        restoreBtn(activeMoveSlot)
    activeMoveSlot := slot
    activeMoveKind := kind
    movePhase      := 0
    moveTimer      := 0
    hiBtn(slot)
    DEBUG(`pnl update)

PRI watchMove() | pitch, roll, done
'' Non-blocking: detect when the active move finishes, then de-highlight it. Poses/head watch the
'' move-complete FALSE->TRUE edge; gestures watch the busy flag; gaits are latched (clear only if the
'' backend leaves GAITING, e.g. a STOP replaced it or the safety floor fired). On a STAND/CROUCH/RELAX
'' completion, log the settled IMU tilt (leveling check / surface baseline).
    if activeMoveSlot < 0
        return
    done := FALSE
    moveTimer++
    case activeMoveKind
        KIND_POSE:
            if movePhase == 0
                if dog.getMoveComplete() == FALSE or moveTimer > 40
                    movePhase := 1
            else
                if dog.getMoveComplete() or moveTimer > 240
                    done := TRUE
        KIND_GEST:
            if movePhase == 0
                if dog.isBusy() or moveTimer > 40
                    movePhase := 1
            else
                if dog.isBusy() == FALSE or moveTimer > 400
                    done := TRUE
        KIND_GAIT:
            if dog.getModeState() <> dog.MODE_GAITING and moveTimer > 8
                done := TRUE
    if done
        if activeMoveSlot == 0 or activeMoveSlot == 2 or activeMoveSlot == 3
            pitch, roll := dog.getAttitude()
            logImuSettle(activeMoveSlot, pitch, roll)
        restoreBtn(activeMoveSlot)
        DEBUG(`pnl update)
        activeMoveSlot := -1

PRI logImuSettle(slot, pitch, roll)
    case slot
        0: DEBUG[DBG_IMU]("IMU after STAND: pitch=", sdec_(pitch), " roll=", sdec_(roll), " deg  (leveled stand; target 0/0)")
        2: DEBUG[DBG_IMU]("IMU after CROUCH: pitch=", sdec_(pitch), " roll=", sdec_(roll), " deg  (crouch is symmetric -- NOT leveled)")
        3: DEBUG[DBG_IMU]("IMU after RELAX: pitch=", sdec_(pitch), " roll=", sdec_(roll), " deg  (resting tuck -- surface/baseline reference)")

PRI stepLed()
'' Step the LED ring through its built-in patterns on each press: OFF -> SOLID -> WIPE -> CHASE ->
'' RAINBOW -> RAINBOW_CYCLE -> OFF. Button lit whenever a pattern (non-OFF) is active.
    ledMode := (ledMode + 1) // LED_MODE_COUNT
    io.postCommand(io.IO_LED_MODE, ledMode, 0, 0, 0)
    if ledMode == 0
        restoreBtn(18)
    else
        hiBtn(18)
    showLedMode(ledMode)                                      ' update the on-screen LED-mode readout in step with the ring
    DEBUG(`pnl update)
    DEBUG[DBG_CMD]("PANEL LED mode=", sdec_(ledMode))

PRI toggleRange()
    if rangeOn
        io.postCommand(io.IO_RANGE_OFF, 0, 0, 0, 0)
        rangeOn := FALSE
        restoreBtn(20)
        DEBUG[DBG_CMD]("PANEL ranging off")
    else
        io.postCommand(io.IO_RANGE_ON, 0, 0, 0, 0)           ' arg0=0 -> default ping interval
        rangeOn := TRUE
        hiBtn(20)
        DEBUG[DBG_CMD]("PANEL ranging on")
    DEBUG(`pnl update)

PRI beep()
    io.postCommand(io.IO_BUZZ_BEEP, 120, 0, 0, 0)
    beepTimer := BEEP_FLASH_POLLS
    hiBtn(19)
    DEBUG(`pnl update)
    DEBUG[DBG_CMD]("PANEL beep")

PRI speak()
'' SPEAK = a "bark" (buzzer) + a head NOD; highlight tracks the nod gesture (KIND_GEST).
    io.postCommand(io.IO_BUZZ_BEEP, SPEAK_BARK_MS, 0, 0, 0)  ' bark
    postDog(dog.CMD_NOD, 0)                                   ' nod while "speaking"
    startMove(29, KIND_GEST)
    DEBUG[DBG_CMD]("PANEL speak (bark + nod)")

PRI setSpeed(v, slot)
'' Radio selector: move the highlight to the chosen speed and set the gait speed (gaits only).
    if speedSlot <> slot
        if speedSlot >= 0
            restoreBtn(speedSlot)
        speedSlot := slot
        hiBtn(slot)
        DEBUG(`pnl update)
    gaitSpeed := v
    dog.postCommand(dog.CMD_SET_SPEED, v, 0, 0, 0)           ' apply live to a running gait (not just the next one)
    DEBUG[DBG_CMD]("PANEL gaitSpeed=", sdec_(v))

PRI hiBtn(slot) | bx, by
    bx, by := btnXY(slot)
    DEBUG(`pnl crop 2 `(0, slot * CELL_H, CELL_W, CELL_H, bx, by))   ' blit highlighted button cell

PRI restoreBtn(slot) | bx, by
    bx, by := btnXY(slot)
    DEBUG(`pnl crop 1 `(bx, by, CELL_W, CELL_H))             ' restore idle button from bg (erase highlight)

PRI btnXY(slot) : x, y
    x := GRID_X + (slot // COLS) * PITCH_X
    y := GRID_Y + (slot / COLS) * PITCH_Y

PRI hitSlot(px, py) : slot | col, row
'' Map a window pixel to a grid slot (row*COLS + col), or -1 if outside any button cell.
'' The PLOT window reports the mouse with a BOTTOM-LEFT origin (Y up); the layout/BMP is authored
'' top-left (Y down). Flip Y here so the grid math matches the artwork (confirmed on bench 2026-06-06).
    slot := -1
    py := (PANEL_H - 1) - py
    if px < GRID_X or py < GRID_Y
        return
    col := (px - GRID_X) / PITCH_X
    row := (py - GRID_Y) / PITCH_Y
    if col > (COLS - 1) or row > (ROWS - 1)
        return
    if ((px - GRID_X) - col * PITCH_X) >= CELL_W             ' in the horizontal gap between cells
        return
    if ((py - GRID_Y) - row * PITCH_Y) >= CELL_H             ' in the vertical gap between rows
        return
    slot := row * COLS + col

PRI keyToSlot(k) : slot
'' Keyboard mirror of the button grid (space = STOP as a panic key).
    slot := -1
    case k
        "1"     : slot := 0
        "2"     : slot := 1
        "3"     : slot := 2
        "4"     : slot := 3
        " "     : slot := 4
        "w","W" : slot := 6
        "x","X" : slot := 7
        "a","A" : slot := 8
        "d","D" : slot := 9
        "z","Z" : slot := 10
        "c","C" : slot := 11
        "h","H" : slot := 12
        "k","K" : slot := 13
        "u","U" : slot := 14
        "j","J" : slot := 15
        "n","N" : slot := 16
        "m","M" : slot := 17
        "l","L" : slot := 18
        "b","B" : slot := 19
        "g","G" : slot := 20
        "-"     : slot := SPEED_SLOW
        "0"     : slot := SPEED_NORM
        "="     : slot := SPEED_FAST
        "o","O" : slot := 24                                 ' DOWN
        "v","V" : slot := 25                                 ' BOW
        "p","P" : slot := 26                                 ' PUSHUP
        "y","Y" : slot := 27                                 ' NOD (yes)
        "i","I" : slot := 28                                 ' SPIN
        "e","E" : slot := 29                                 ' SPEAK

PRI setupWindow()
    DEBUG(`plot pnl title 'P2 Robot Dog -- Move Panel' size 660 510 pos 300 120 hidexy update)
    DEBUG(`pnl layer 1 'dog_panel_bg.bmp')
    DEBUG(`pnl layer 2 'dog_btn_hi.bmp')
    DEBUG(`pnl layer 3 'dog_font.bmp')
    DEBUG(`pnl layer 4 'dog_modes.bmp')
    DEBUG(`pnl layer 5 'dog_led_modes.bmp')
    DEBUG(`pnl crop 1)
    DEBUG(`pnl update)

PRI refreshReadouts() | mode, mv, pitch, roll, hc, ht, dist, ping
'' Poll the production getters and repaint the six readout fields; one UPDATE flips them together.
    mode := dog.getModeState()
    mv   := dog.getBatteryMilliVolts()
    pitch, roll := dog.getAttitude()
    hc, ht := dog.getHead()
    dist := io.getDistanceMm()
    ping := io.getPingSeq()

    showMode(mode)
    showRight(RO_BATT_BX, RO_BATT_BY, RO_BATT_BW, RO_BATT_S0, 4, 0 #> mv <# 9999)
    showRight(RO_HEAD_BX, RO_HEAD_BY, RO_HEAD_BW, RO_HEAD_S0, 3, 0 #> hc <# 999)
    showTilt(pitch, roll)
    showRight(RO_DIST_BX, RO_DIST_BY, RO_DIST_BW, RO_DIST_S0, 4, 0 #> dist <# 9999)
    showRight(RO_PING_BX, RO_PING_BY, RO_PING_BW, RO_PING_S0, 5, 0 #> ping <# 99999)
    DEBUG(`pnl update)

PRI showMode(mode) | m
    m := 0 #> mode <# 4
    DEBUG(`pnl crop 1 `(RO_MODE_BX, RO_MODE_BY, RO_MODE_BW, RO_BOX_H))                ' erase
    DEBUG(`pnl crop 4 `(0, m * MODE_CELL_H, MODE_CELL_W, MODE_CELL_H, RO_MODE_BX, RO_MODE_BY + 4))

PRI showLedMode(mode) | m
'' Paint the active LED-mode name (layer 5 word strip) + its index digit into the LED readout box.
'' Panel-side state (ledMode), not a dog getter -- driven from stepLed() and once at startup. Caller flips with UPDATE.
    m := 0 #> mode <# (LED_MODE_COUNT - 1)
    DEBUG(`pnl crop 1 `(RO_LED_BX, RO_LED_BY, RO_LED_BW, RO_BOX_H))                   ' erase
    DEBUG(`pnl crop 5 `(0, m * LED_CELL_H, LED_CELL_W, LED_CELL_H, RO_LED_BX, RO_LED_BY + 4))   ' mode name (layer 5)
    blitGlyph(m, RO_LED_S0, RO_LED_BY + 2)                                            ' index digit (layer 3 font)

PRI showRight(bx, by, bw, s0, n, value) | v, x, i, d
'' Erase the box, then blit up to n digits of value right-aligned (leading zeros suppressed).
    DEBUG(`pnl crop 1 `(bx, by, bw, RO_BOX_H))               ' erase value box (restore bg)
    v := value
    x := s0 + (n - 1) * RW                                   ' rightmost digit slot
    repeat i from 0 to n - 1
        d := v // 10
        if (i == 0) or (v > 0)
            blitGlyph(d, x, by + 2)
        v := v / 10
        x -= RW

PRI showTilt(pitch, roll) | ap, ar, ty
'' P sign+2 digits in slots 0..2, R sign+2 digits in slots 4..6 (slot 3 is the gap).
    ty := RO_TILT_BY + 2
    DEBUG(`pnl crop 1 `(RO_TILT_BX, RO_TILT_BY, RO_TILT_BW, RO_BOX_H))                ' erase
    ap := abs(pitch) <# 99
    if pitch < 0
        blitGlyph(GLYPH_MINUS, RO_TILT_S0, ty)
    if ap > 9
        blitGlyph(ap / 10, RO_TILT_S0 + RW, ty)
    blitGlyph(ap // 10, RO_TILT_S0 + 2 * RW, ty)
    ar := abs(roll) <# 99
    if roll < 0
        blitGlyph(GLYPH_MINUS, RO_TILT_S0 + 4 * RW, ty)
    if ar > 9
        blitGlyph(ar / 10, RO_TILT_S0 + 5 * RW, ty)
    blitGlyph(ar // 10, RO_TILT_S0 + 6 * RW, ty)

PRI blitGlyph(g, destX, destY)
    DEBUG(`pnl crop 3 `(g * RW, 0, RW, RH, destX, destY))

PRI countdown() | s
    repeat s from COUNTDOWN_S to 1
        DEBUG("  ", udec_(s), " ...")
        waitms(1000)
