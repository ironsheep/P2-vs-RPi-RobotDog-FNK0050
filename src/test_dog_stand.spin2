{Spin2_v47}
'' =================================================================================================
''   File....... test_dog_stand.spin2
''   Purpose.... POSE/STAND bench scenario in the PRODUCTION 3-cog shape. Launches BOTH service cogs
''               (cog1 backend/I2C, cog2 IO/discrete pins) exactly as the real runtime does, then the
''               cog0 test facility drives ONLY mailbox A (poses + head) -- the IO cog stays quiescent
''               (static "alive" LED, ranging dormant). Isolates the motion engine + eased poses while
''               testing the real cog topology, never a non-production shape.
''   Authors.... Stephen M Moraco -- (c) 2026 Iron Sheep Productions, LLC  (MIT)
'' =================================================================================================
'
'  >> LIFT/SUPPORT THE ROBOT << -- on launch cog1 calibrates the gyro (hold still) then STANDS via IK.
'  cog2 comes up first (owns no shared bus) showing a static dim-green LED = "IO cog alive"; it fires
'  NO ranging and NO animation, so the unproven smart-pin path stays dormant for this motion-only test.
'  Run:
'    pnut-ts -d -q src/test_dog_stand.spin2
'    pnut-term-ts -r src/test_dog_stand.bin -b 2000000 --headless --end-marker "STAND_DONE" --timeout 75

CON
  _clkfreq      = 200_000_000
  DEBUG_BAUD    = 2_000_000

  ' as-built pin map (DOCs/P2_MIGRATION_WIRING.md sec.3; verified 2026-05-31)
  PIN_SCL       = 13                  ' I2C clock  (cog1, mailbox A)
  PIN_SDA       = 15                  ' I2C data
  PIN_WS2812    = 8                   ' LED data   (cog2, mailbox B)
  PIN_ECHO      = 9                   ' HC-SR04 ECHO (in, ~1 kohm series R)
  PIN_BUZZER    = 10                  ' buzzer
  PIN_TRIG      = 11                  ' HC-SR04 TRIG

  COUNTDOWN_S   = 8
  COG_STACK     = 256
  INIT_MS       = 5000               ' allow cog1 init + gyro cal + initial STAND
  COLOR_ALIVE   = $00_20_00          ' dim green = "IO cog alive" (static, no animation, no ranging)

OBJ
  dog     : "isp_robot_dog"                                  ' cog1: I2C bus owner, mailbox A
  io      : "isp_io_controller"                              ' cog2: discrete pins, mailbox B (quiescent here)
  version : "isp_version"
  stack   : "isp_stack_check"                                ' COG stack-overflow detector

DAT ' ---- cog launch stacks, each followed IMMEDIATELY by its overflow sentinel ----
  backendStack     LONG  0[COG_STACK]
  backendStackMark LONG  stack.DO_NOT_WRITE_MARK
  ioStack          LONG  0[COG_STACK]
  ioStackMark      LONG  stack.DO_NOT_WRITE_MARK

PUB main() | backendCog, ioCog
'' Launch the production 3-cog shape, then drive only poses on mailbox A.

    waitms(100)
    DEBUG("=== POSE/STAND scenario (production 3-cog shape) ===")
    DEBUG("    firmware v", udec_(version.FW_VERSION_MAJOR), ".", udec_(version.FW_VERSION_MINOR), ".", udec_(version.FW_VERSION_PATCH))
    DEBUG(">> LIFT/SUPPORT THE ROBOT. cog1 calibrates gyro (hold still) then STANDS via IK. <<")
    countdown()

    stack.prepStackForCheck(@ioStack, COG_STACK)             ' fill pattern + sentinel BEFORE launch
    stack.prepStackForCheck(@backendStack, COG_STACK)

    ioCog := cogspin(NEWCOG, io.start(PIN_WS2812, PIN_BUZZER, PIN_TRIG, PIN_ECHO), @ioStack)
    if ioCog < 0
        abortRun(string("FAILED to start IO cog"))
    io.setStackCheck(@ioStack, COG_STACK)                    ' IO cog now self-watches its stack
    io.postCommand(io.IO_LED_SOLID, COLOR_ALIVE, 0, 0, 0)     ' static "alive" indicator; ranging stays OFF
    DEBUG("IO cog alive in cog ", udec_(ioCog), " (quiescent: static LED, ranging dormant)")

    backendCog := cogspin(NEWCOG, dog.start(PIN_SCL, PIN_SDA), @backendStack)
    if backendCog < 0
        abortRun(string("FAILED to start backend cog"))
    dog.setStackCheck(@backendStack, COG_STACK)              ' backend cog now self-watches its stack
    DEBUG("backend cog ", udec_(backendCog), "; init + gyro cal + initial STAND...")
    waitms(INIT_MS)
    reportMove(string("init STAND (power-on seed)"))

    postAndReport(dog.CMD_RELAX,  0, string("RELAX"))
    postAndReport(dog.CMD_STAND,  0, string("STAND"))
    postAndReport(dog.CMD_SIT,    0, string("SIT"))
    postAndReport(dog.CMD_STAND,  0, string("STAND"))
    postAndReport(dog.CMD_HEAD,  60, string("HEAD 60"))
    postAndReport(dog.CMD_HEAD, 120, string("HEAD 120"))
    postAndReport(dog.CMD_HEAD,  90, string("HEAD 90"))

    DEBUG("pose scenario done")
    DEBUG("STAND_DONE")
    repeat

PRI postAndReport(cmd, arg, pNameStr) | guard
' Post a command, watch the move-complete FALSE->TRUE edge, then dump per-leg targets/current/angles.
' Bounded waits so a no-op move can never hang the run.
'
' @param cmd - CMD_* to post
' @param arg - command arg0
' @param pNameStr - label for the dump
' @local guard - bounded-wait iteration counter

    DEBUG("-- post ", zstr_(pNameStr), " --")
    dog.postCommand(cmd, arg, 0, 0, 0)
    guard := 0
    repeat while dog.getMoveComplete() and (guard++ < 200)    ' up to ~2 s for the backend to start the move
        waitms(10)
    guard := 0
    repeat until dog.getMoveComplete() or (guard++ > 500)     ' up to ~5 s for the move to finish
        waitms(10)
    reportMove(pNameStr)

PRI reportMove(pNameStr) | idx, tx, ty, tz, cx, cy, cz, ca, fa, ta, hc, ht
' Dump the move enum + every leg's target XYZ, current XYZ, and last servo angles, then head+battery.
'
' @param pNameStr - label for this dump
' @local idx - leg index; tx/ty/tz target; cx/cy/cz current; ca/fa/ta servo angles; hc/ht head

    DEBUG("== ", zstr_(pNameStr), " done  (moveKind=", udec_(dog.getMoveKind()), ") ==")
    repeat idx from 0 to 3
        tx, ty, tz := dog.getLegTarget(idx)
        cx, cy, cz := dog.getLegCurrent(idx)
        ca, fa, ta := dog.getLegServoAngles(idx)
        DEBUG("  ", zstr_(legName(idx)), " tgt(", sdec_(tx), ",", sdec_(ty), ",", sdec_(tz), ")  cur(", sdec_(cx), ",", sdec_(cy), ",", sdec_(cz), ")  servo c/f/t=", sdec_(ca), "/", sdec_(fa), "/", sdec_(ta))
    hc, ht := dog.getHead()
    DEBUG("  HEAD cur=", sdec_(hc), " tgt=", sdec_(ht), "   battery=", udec_(dog.getBatteryMilliVolts()), " mV")

PRI legName(idx) : pStr
' Short label for a leg index (0=FL 1=BL 2=FR 3=BR).
    case idx
        0: pStr := string("FL")
        1: pStr := string("BL")
        2: pStr := string("FR")
        3: pStr := string("BR")
        other: pStr := string("??")

PRI countdown() | i
    repeat i from COUNTDOWN_S to 1
        DEBUG("  launch in ", udec_(i), " s ...")
        waitms(1000)

PRI abortRun(pReasonStr)
    DEBUG(zstr_(pReasonStr))
    DEBUG("STAND_DONE")
    repeat
