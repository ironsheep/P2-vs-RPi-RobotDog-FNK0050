  CMD_TAKE_PHOTOS_AND_SAVE_THEM     = 50
  CMD_SAVE_AND_RETURN               = 51
  CMD_DISPLAY_NUMBER_ZERO           = 52
  CMD_DISPLAY_NUMBER_ONE            = 53
  CMD_DISPLAY_NUMBER_TWO            = 54
  CMD_DISPLAY_NUMBER_THREE          = 55
  CMD_DISPLAY_NUMBER_FOUR           = 56
  CMD_DISPLAY_NUMBER_FIVE           = 57
  CMD_DISPLAY_NUMBER_SIX            = 58
  CMD_DISPLAY_NUMBER_SEVEN          = 59
  CMD_DISPLAY_NUMBER_EIGHT          = 60
  CMD_DISPLAY_NUMBER_NINE           = 61
  CMD_DISPLAY_SMILEY_FACE           = 62
  CMD_DISPLAY_CRYING_FACE           = 63
  CMD_DISPLAY_HEART                 = 64
  CMD_TURN_OFF_DOT_MATRIX           = 65
  CMD_READ_CURRENT_POSTURE          = 66
  CMD_READ_AMBIENT_LIGHT            = 67
  CMD_READ_COMPASS                  = 68
  CMD_READ_TEMPERATURE              = 69
  CMD_READ_ACCELERATION             = 70
