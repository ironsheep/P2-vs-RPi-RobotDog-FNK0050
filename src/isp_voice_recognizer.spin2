{Spin2_v46}                                                    ' enables channel-based DEBUG[n]() / DEBUG_MASK
'' =================================================================================================
''
''   File....... isp_voice_recognizer.spin2
''   Purpose.... P2 driver for the DFRobot DF2301Q "Gravity" offline voice-recognition sensor
''               (SKU SEN0539) over I2C.  Hands the application the recognized command ID (CMDID),
''               plays reply audio, and configures volume / mute / wake-duration.
''   Author..... Stephen M Moraco
''               Copyright (c) 2026 Iron Sheep Productions, LLC
''               -- see end of file for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... 03 Jun 2026
''   Updated.... 07 Jun 2026
''
''   Rests on... isp_i2c_singleton (bit-banged I2C bus, shared singleton)
''   See........ DOCs/design/DRIVER-THEORY-OF-OPERATIONS.md (how this driver works)
''               DOCs/reference/THEORY-OF-OPERATIONS.md   (device protocol / reference library)
''
'' =================================================================================================


CON ' ---- Public Command-Word IDs ----

  {Spin2_Doc_CON}
  ' Command-word IDs reported by getCMDID()/pollCMDID().  0 means "nothing recognized."  These are the
  ' DF2301Q's built-in fixed vocabulary (ported from the DFRobot reference DFRobot_DF2301Q_Commands.py);
  ' the human phrase for an ID is available from the optional isp_voice_command_names object (cmdName()).
  ' Constants cost nothing unless referenced.  VALIDATE against the product's printed command-word
  ' card on hardware (#9) -- firmware revisions have reshuffled lists.

  ' sentinel & wake words
  CMD_NONE                          = 0    ' Silence / nothing recognized
  CMD_WAKE_LEARN                    = 1    ' WakeUpWordsForLearning
  CMD_HELLO_ROBOT                   = 2    ' HelloRobot (default wake word)
  ' NOTE: which CMDID enterWakeState() plays to wake the module is resolved on hardware
  '       (reference finding F1) -- see DOCs/plans sec 9 / task #9.

  ' custom slots (user-trained; the spoken phrase is whatever you record)
  CMD_CUSTOM_1                      = 5
  CMD_CUSTOM_2                      = 6
  CMD_CUSTOM_3                      = 7
  CMD_CUSTOM_4                      = 8
  CMD_CUSTOM_5                      = 9
  CMD_CUSTOM_6                      = 10
  CMD_CUSTOM_7                      = 11
  CMD_CUSTOM_8                      = 12
  CMD_CUSTOM_9                      = 13
  CMD_CUSTOM_10                     = 14
  CMD_CUSTOM_11                     = 15
  CMD_CUSTOM_12                     = 16
  CMD_CUSTOM_13                     = 17
  CMD_CUSTOM_14                     = 18
  CMD_CUSTOM_15                     = 19
  CMD_CUSTOM_16                     = 20
  CMD_CUSTOM_17                     = 21

  ' built-in fixed commands (note: 28 is skipped in the reference list)
  CMD_GO_FORWARD                    = 22
  CMD_RETREAT                       = 23
  CMD_PARK_A_CAR                    = 24
  CMD_TURN_LEFT_90_DEG              = 25   ' TurnLeftNinetyDegrees
  CMD_TURN_LEFT_45_DEG              = 26   ' TurnLeftFortyFiveDegrees
  CMD_TURN_LEFT_30_DEG              = 27   ' TurnLeftThirtyDegrees
  CMD_TURN_RIGHT_45_DEG             = 29   ' TurnRightFortyFiveDegrees
  CMD_TURN_RIGHT_30_DEG             = 30   ' TurnRightThirtyDegrees
  CMD_SHIFT_DOWN_A_GEAR             = 31
  CMD_LINE_TRACKING_MODE            = 32
  CMD_LIGHT_TRACKING_MODE           = 33
  CMD_BLUETOOTH_MODE                = 34
  CMD_OBSTACLE_AVOIDANCE_MODE       = 35
  CMD_FACE_RECOGNITION              = 36
  CMD_OBJECT_TRACKING               = 37
  CMD_OBJECT_RECOGNITION            = 38
  CMD_LINE_TRACKING                 = 39
  CMD_COLOR_RECOGNITION             = 40
  CMD_TAG_RECOGNITION               = 41
