  CMD_SET_SERVO_45_DEG              = 85   ' SetServoToFortyFiveDegrees
  CMD_SET_SERVO_60_DEG              = 86   ' SetServoToSixtyDegrees
  CMD_SET_SERVO_90_DEG              = 87   ' SetServoToNinetyDegrees
  CMD_TURN_ON_THE_BUZZER            = 88
