'' =================================================================================================
''
''   File....... isp_voice_command_names.spin2
''   Purpose.... OPTIONAL human-readable phrase lookup for DF2301Q command-word IDs, plus an
''               application registration API for the 17 user-trained CUSTOM words (IDs 5..21).
''               Include this object only when you want phrase strings (e.g. to print the recognized
''               command); it adds the string table to the binary. Apps that only need to react by
''               ID use the CMD_* constants in isp_voice_recognizer (which are free).
''   Author..... Stephen M Moraco
''               Copyright (c) 2026 Iron Sheep Productions, LLC
''               -- see end of file for terms of use
''   E-mail..... stephen@ironsheep.biz
''   Started.... 04 Jun 2026
''   Updated.... 07 Jun 2026
''
''   Note....... Built-in IDs/phrases mirror isp_voice_recognizer's CMD_* constants (both ported from
''               the DFRobot reference DFRobot_DF2301Q_Commands.py). Validate against the product's
''               command-word card (#9). The built-in table below is GENERATED -- see the markers.
''
'' =================================================================================================


CON ' ---- Custom Command-Word Registration ----

  ' The device trains custom words BY VOICE and only ever reports their slot ID (5..21); it stores no
  ' text. So the application is the sole source of truth for what each custom slot means. An app
  ' declares its custom vocabulary as an inline table and registers it once (registerCustomTable);
  ' cmdName() then returns the registered phrase for those IDs. See DOCs/USER-GUIDE.md for the
  ' copy-paste table exemplar.
  CUSTOM_FIRST  = 5                                            ' = CMD_CUSTOM_1  in isp_voice_recognizer
  CUSTOM_LAST   = 21                                           ' = CMD_CUSTOM_17 in isp_voice_recognizer
  CUSTOM_COUNT  = 17                                           ' number of custom slots
  CUSTOM_MAXLEN = 63                                           ' longest custom phrase accepted (terminator-scan bound)

  ' registerCustomTable() result / reason codes
  REG_OK             =  0                                      ' table validated and registered
  REG_E_INDEX        = -1                                      ' an entry's index byte is outside CUSTOM_FIRST..CUSTOM_LAST
  REG_E_UNTERMINATED = -2                                      ' an entry's phrase had no 0 within CUSTOM_MAXLEN bytes
  REG_E_TOO_MANY     = -3                                      ' more than CUSTOM_COUNT entries before the end marker
  REG_E_DUP          = -4                                      ' the same custom index appears more than once


VAR ' per-instance custom-word registry

  long  customPtr[CUSTOM_COUNT]                                ' absolute ptr to each slot's phrase (0 = unregistered)


PUB null()
'' This is not a top-level object.
''


PUB registerCustomTable(pTable) : status | pScan, slot, nLen, count, seen
'' Validate an application's inline custom-word table and register it (one-time analysis).
''
'' Table format -- build it in your DAT and pass @yourTable (copy the exemplar in DOCs/USER-GUIDE.md):
'' each entry is one index byte (a custom slot, CUSTOM_FIRST..CUSTOM_LAST) followed immediately by a
'' zero-terminated phrase; a single 0 index byte ends the table. Phrases are variable length and may
'' be multi-word. Nothing is registered unless the WHOLE table validates (all-or-nothing).
''
'' @param pTable - pointer to the application's inline custom-word table
'' @returns status - REG_OK, or a negative REG_E_* reason code (nothing registered on reject)

' Local Variables:
' @local pScan - walking pointer over the table
' @local slot - current entry's index byte
' @local nLen - measured (bounded) phrase length
' @local count - entries validated so far
' @local seen - bitmap of slots already used (duplicate detection)

  status := REG_OK
  pScan := pTable
  count := 0
  seen := 0
  repeat
    slot := byte[pScan]
    if slot == 0
      quit                                                     ' end-of-table marker
    if (slot < CUSTOM_FIRST) or (slot > CUSTOM_LAST)
      status := REG_E_INDEX
      quit
    if seen & (1 << (slot - CUSTOM_FIRST))
      status := REG_E_DUP
      quit
    nLen := boundedLen(pScan + 1, CUSTOM_MAXLEN)
    if nLen < 0
      status := REG_E_UNTERMINATED
      quit
    seen |= (1 << (slot - CUSTOM_FIRST))
    count++
    if count > CUSTOM_COUNT
      status := REG_E_TOO_MANY
      quit
    pScan += 1 + nLen + 1                                       ' advance past index + phrase + terminator
  if status == REG_OK                                          ' commit only when the whole table is clean
    longfill(@customPtr, 0, CUSTOM_COUNT)
    pScan := pTable
    repeat while byte[pScan]
      slot := byte[pScan]
      customPtr[slot - CUSTOM_FIRST] := pScan + 1              ' absolute ptr (pTable was absolute)
      pScan += 1 + strsize(pScan + 1) + 1


PUB clearCustomWords()
'' Forget all registered custom phrases; cmdName() reverts to "(custom)" for IDs 5..21.
''

  longfill(@customPtr, 0, CUSTOM_COUNT)


' >>> GENERATED cmd-name table (tools/gen_cmdname_table.py --apply from tools/cmdname_catalog.tsv) -- do not hand-edit

PUB cmdName(cmdId) : pStr
'' Return a pointer to the human-readable phrase for a command-word ID (dense indexed table).
''
'' @param cmdId - command-word ID to look up
'' @returns pStr - pointer to the phrase ((none) for 0, registered/(custom) for 5..21, (unknown) if unmapped)

  pStr := @nm_unknown                                          ' default: ID-space gaps and out-of-range
  ' Resolve via the explicit typed form @@WORD[@table][i] (Spin2 KB "lookup table of @offsets" idiom):
  ' read the stored object-relative WORD offset, THEN add the object base. The bare @@nmTbl_0[i] form
  ' mis-compiled under pnut-ts -- it yielded the table-ENTRY address, so zstr_() walked the (zero-free)
  ' offset table and dumped it as binary (one byte was $1B = DEBUG_END_SESSION). Fixed 2026-06-10.
  case cmdId
    0..2:      pStr := @@WORD[@nmTbl_0][cmdId]
    5..21:     pStr := customWord(cmdId)
    22..27:    pStr := @@WORD[@nmTbl_22][cmdId - 22]
    29..142:   pStr := @@WORD[@nmTbl_29][cmdId - 29]
    200..208:  pStr := @@WORD[@nmTbl_200][cmdId - 200]


DAT ' ---- Command-Word Phrase Table (dense indexed) ----

' One dense WORD array per contiguous ID run; cmdName() range-checks cmdId and indexes the
' matching array (base-offset subtracted). Entries are object-relative WORD offsets, resolved
' at runtime with @@. No storage is spent on the ID-space gaps; IDs 5..21 route to customWord().

nmTbl_0 ' IDs 0..2
            word    @nm_none        ' 0
            word    @nm_001         ' 1
            word    @nm_002         ' 2

nmTbl_22 ' IDs 22..27
            word    @nm_022         ' 22
            word    @nm_023         ' 23
            word    @nm_024         ' 24
            word    @nm_025         ' 25
            word    @nm_026         ' 26
            word    @nm_027         ' 27

