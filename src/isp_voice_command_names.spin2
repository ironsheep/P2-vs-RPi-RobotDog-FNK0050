PRI customWord(cmdId) : pStr
' Registered custom phrase for a custom slot (CUSTOM_FIRST..CUSTOM_LAST), or "(custom)" if none.
'
' @param cmdId - custom command-word ID (assumed already range-checked by the cmdName dispatcher)
' @returns pStr - registered phrase pointer, or @nm_custom if the slot is unregistered

  pStr := @nm_custom
  if customPtr[cmdId - CUSTOM_FIRST]
    pStr := customPtr[cmdId - CUSTOM_FIRST]


PRI boundedLen(pStr, maxLen) : nLen | idx
' Return the string length if a 0 terminator is found within maxLen bytes, else -1.
'
' @param pStr - pointer to the candidate string
' @param maxLen - maximum bytes to scan for the terminator
' @returns nLen - length (offset of the 0) if terminated within maxLen, else -1

' Local Variables:
' @local idx - scan offset

  nLen := -1
  repeat idx from 0 to maxLen - 1
    if byte[pStr][idx] == 0
      nLen := idx
      quit


