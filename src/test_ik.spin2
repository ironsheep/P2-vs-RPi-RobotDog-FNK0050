'' =================================================================================================
''   File....... test_ik.spin2
''   Purpose.... DIAGNOSTIC: print the CORDIC IK joint angles (degrees) for known foot targets.
''               Pure math -- no servos, no I2C, no power needed. Verifies isp_leg.solveIKdegrees().
''   Authors.... Stephen M Moraco -- (c) 2026 Iron Sheep Productions, LLC  (MIT)
'' =================================================================================================
'
'  Run headless (no robot): pnut-ts -d -q src/test_ik.spin2
'                           pnut-term-ts -r src/test_ik.bin -b 2000000 --headless --end-marker "TEST_DONE"
'  Loaded-rear-crouch neutral (IK frame): FRONT [0,95,10] ~ a 84, b -49, c 98 ;
'  REAR [-12,85,10] ~ c 109 (rear knee more flexed -> deeper fold). Knee bent -> foot reaches down.

CON
  _clkfreq   = 200_000_000
  DEBUG_BAUD = 2_000_000

OBJ
  leg : "isp_leg"

PUB main()
    waitms(100)
    DEBUG("=== IK dry-run (degrees, IK frame: coxa/femur/tibia) ===")
    showIK(0, 95, 10)            ' FRONT neutral (front/left lateral)
    showIK(-12, 85, 10)          ' REAR neutral (tucked toward tail, deeper fold)
    showIK(0, 110, 0)            ' straight down, max reach (l2+l3)
    showIK(0, 60, 0)             ' tucked short
    showIK(20, 99, 10)           ' reach forward
    showIK(55, 78, 0)            ' relax pose
    DEBUG("TEST_DONE")
    repeat

PRI showIK(footX, footY, footZ) | aDeg, bDeg, cDeg
    aDeg, bDeg, cDeg := leg.solveIKdegrees(footX, footY, footZ)
    DEBUG("  XYZ(", sdec_(footX), ",", sdec_(footY), ",", sdec_(footZ), ") -> a=", sdec_(aDeg), " b=", sdec_(bDeg), " c=", sdec_(cDeg))
