'' =================================================================================================
''   File....... test_gaits.spin2
''   Purpose.... Gait-catalog bench harness. Launch the backend body-control cog (isp_robot_dog) and
''               drive EVERY gait + the speed knob through the production mailbox (dog.postCommand) --
''               the real IO path, not a bespoke servo harness. Companion to test_backend (poses) and
''               test_level (IMU): this one exercises plan sec.3, the full gait catalog.
''   Authors.... Stephen M Moraco -- (c) 2026 Iron Sheep Productions, LLC  (MIT)
'' =================================================================================================
'
'  Download-to-RAM and run (DEBUG @ 2 Mbaud). >> LIFT/SUPPORT THE ROBOT << -- on launch the backend
'  configures the controller, applies calibration, calibrates the gyro (hold still), and STANDS via
'  IK; then we post each gait in turn, STOP-easing to neutral between them. Run:
'    pnut-ts -d -q src/test_gaits.spin2
'    pnut-term-ts -r src/test_gaits.bin -b 2000000 --headless --end-marker "TEST_DONE" --timeout 120
'
'  Each gait is LATCHED (one post sustains it); CMD_STOP eases back to neutral before the next. The
'  speed segment shows arg0 (deg/frame) changing cadence: slow (5) then fast (30) vs default (0).

CON
  _clkfreq      = 200_000_000
  DEBUG_BAUD    = 2_000_000
  PIN_SCL       = 13
  PIN_SDA       = 15
  COUNTDOWN_S   = 8
  COG_STACK     = 256
  INIT_MS       = 5000               ' allow init + gyro cal + initial STAND
  GAIT_MS       = 4000               ' run each gait long enough to judge direction + smoothness
  SETTLE_MS     = 2500               ' STOP-ease back to neutral between gaits
  SPEED_SLOW    = 5                  ' deg/frame (smooth, slow cadence)
  SPEED_FAST    = 30                 ' deg/frame (brisk cadence)

OBJ
  dog : "isp_robot_dog"

VAR
  long  cogStack[COG_STACK]

PUB main() | i, backendCog
    waitms(100)
    DEBUG("=== GAIT CATALOG bench: launch isp_robot_dog, drive every gait via mailbox ===")
    DEBUG(">> LIFT/SUPPORT THE ROBOT. It will calibrate gyro (hold still) then STAND via IK. <<")
    repeat i from COUNTDOWN_S to 1
        DEBUG("  launch in ", udec_(i), " s ...")
        waitms(1000)

    backendCog := cogspin(NEWCOG, dog.start(PIN_SCL, PIN_SDA), @cogStack)
    if backendCog < 0
        DEBUG("FAILED to start backend cog -- aborting")
        DEBUG("TEST_DONE")
        repeat
    DEBUG("backend launched in cog ", udec_(backendCog), "; init + gyro cal + initial STAND...")
    waitms(INIT_MS)
    reportTelemetry()

    ' ---- the six gaits, each latched then eased to neutral (default speed, arg0 = 0) ----
    runGait(string("FORWARD"),    dog.CMD_FORWARD,    0)
    runGait(string("BACKWARD"),   dog.CMD_BACKWARD,   0)
    runGait(string("TURN LEFT"),  dog.CMD_TURN_LEFT,  0)
    runGait(string("TURN RIGHT"), dog.CMD_TURN_RIGHT, 0)
    runGait(string("STEP LEFT"),  dog.CMD_STEP_LEFT,  0)
    runGait(string("STEP RIGHT"), dog.CMD_STEP_RIGHT, 0)

    ' ---- speed knob: same gait (FORWARD), slow then fast -- cadence visibly changes ----
    DEBUG("-- SPEED knob: FORWARD slow (arg0=", udec_(SPEED_SLOW), ") then fast (arg0=", udec_(SPEED_FAST), ") --")
    runGait(string("FORWARD @slow"), dog.CMD_FORWARD, SPEED_SLOW)
    runGait(string("FORWARD @fast"), dog.CMD_FORWARD, SPEED_FAST)

    DEBUG("gait catalog exercise done")
    DEBUG("TEST_DONE")
    repeat

PRI runGait(pNameStr, gaitCmd, speedArg)
' Post one latched gait, let it run, report mode (expect MODE_GAITING=1), then STOP-ease to neutral.
'
' @param pNameStr - human label for this gait
' @param gaitCmd - the CMD_* gait id
' @param speedArg - arg0 speed (deg/frame, 0 = default)

    DEBUG("-- gait: ", zstr_(pNameStr), " (cmd=", udec_(gaitCmd), " speed=", udec_(speedArg), ") --")
    dog.postCommand(gaitCmd, speedArg, 0, 0, 0)
    waitms(GAIT_MS)
    reportTelemetry()
    dog.postCommand(dog.CMD_STOP, 0, 0, 0, 0)                 ' eases to neutral stance (no snap)
    waitms(SETTLE_MS)
    reportTelemetry()

PRI reportTelemetry() | milliVolts, mode, pitchDeg, rollDeg
    milliVolts := dog.getBatteryMilliVolts()
    mode := dog.getModeState()
    pitchDeg, rollDeg := dog.getAttitude()
    DEBUG("   telem: battery=", udec_(milliVolts), " mV  mode=", udec_(mode), "  tilt p=", sdec_(pitchDeg), " r=", sdec_(rollDeg))
