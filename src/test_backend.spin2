'' =================================================================================================
''   File....... test_backend.spin2
''   Purpose.... Launch the backend body-control cog (isp_robot_dog) and drive ALL motion through it
''               via the mailbox -- the production IO path. Replaces the standalone motion harnesses.
''   Authors.... Stephen M Moraco -- (c) 2026 Iron Sheep Productions, LLC  (MIT)
'' =================================================================================================
'
'  Download-to-RAM and run (DEBUG @ 2 Mbaud). >> LIFT/SUPPORT THE ROBOT << -- on launch the backend
'  configures the controller, applies calibration, calibrates the gyro (hold still), and STANDS via
'  IK; then we post commands. 15 s countdown before launch. Run:
'    pnut-ts -d -q src/test_backend.spin2
'    pnut-term-ts -r src/test_backend.bin -b 2000000 --headless --end-marker "TEST_DONE" --timeout 70

CON
  _clkfreq      = 200_000_000
  DEBUG_BAUD    = 2_000_000
  PIN_SCL       = 13
  PIN_SDA       = 15
  COUNTDOWN_S   = 8                 ' shorter so the init STAND (after gyro cal) is easy to see
  COG_STACK     = 256

OBJ
  dog : "isp_robot_dog"

VAR
  long  cogStack[COG_STACK]

PUB main() | i, backendCog
    waitms(100)
    DEBUG("=== BACKEND COG bring-up: launch isp_robot_dog, drive via mailbox ===")
    DEBUG(">> LIFT/SUPPORT THE ROBOT. It will calibrate gyro (hold still) then STAND via IK. <<")
    repeat i from COUNTDOWN_S to 1
        DEBUG("  launch in ", udec_(i), " s ...")
        waitms(1000)

    backendCog := cogspin(NEWCOG, dog.start(PIN_SCL, PIN_SDA), @cogStack)
    if backendCog < 0
        DEBUG("FAILED to start backend cog -- aborting")
        DEBUG("TEST_DONE")
        repeat
    DEBUG("backend launched in cog ", udec_(backendCog), "; init + gyro cal + initial STAND...")
    waitms(5000)                                             ' allow init, gyro calibration, stand
    reportTelemetry()

    DEBUG("-- post CMD_RELAX (tuck) --")
    dog.postCommand(dog.CMD_RELAX, 0, 0, 0, 0)
    waitms(3000)
    reportTelemetry()

    DEBUG("-- post CMD_STAND (neutral stance) --")
    dog.postCommand(dog.CMD_STAND, 0, 0, 0, 0)
    waitms(3000)
    reportTelemetry()

    DEBUG("-- post CMD_SIT --")
    dog.postCommand(dog.CMD_SIT, 0, 0, 0, 0)
    waitms(3000)
    reportTelemetry()

    DEBUG("-- post CMD_STAND --")
    dog.postCommand(dog.CMD_STAND, 0, 0, 0, 0)
    waitms(3000)

    DEBUG("-- head pan: 60, 120, 90 --")
    dog.postCommand(dog.CMD_HEAD, 60, 0, 0, 0)
    waitms(1200)
    dog.postCommand(dog.CMD_HEAD, 120, 0, 0, 0)
    waitms(1200)
    dog.postCommand(dog.CMD_HEAD, 90, 0, 0, 0)
    waitms(1200)

    DEBUG("backend exercise done")
    DEBUG("TEST_DONE")
    repeat

PRI reportTelemetry() | milliVolts, mode, pitchDeg, rollDeg
    milliVolts := dog.getBatteryMilliVolts()
    mode := dog.getModeState()
    pitchDeg, rollDeg := dog.getAttitude()
    DEBUG("   telem: battery=", udec_(milliVolts), " mV  mode=", udec_(mode), "  tilt p=", sdec_(pitchDeg), " r=", sdec_(rollDeg))
